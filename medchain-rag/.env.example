# MedChain RAG Service — Environment Configuration
# Copy this file to .env and fill in your values

# ── Database ───────────────────────────────────────────────────────────────────
# Path to the Django SQLite database (relative to medchain-rag/)
DB_PATH=../medchain-server/db.sqlite3

# ── FAISS Index Storage ────────────────────────────────────────────────────────
FAISS_INDEX_PATH=./data/faiss.index
FAISS_META_PATH=./data/faiss_meta.json

# ── Embedding Model ────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=400
CHUNK_OVERLAP=80

# ── Retrieval ──────────────────────────────────────────────────────────────────
TOP_K=5

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: "gemini" | "ollama"
LLM_PROVIDER=gemini

# Google Gemini (get free key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-1.5-flash

# Ollama (if using local model instead)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Auth ───────────────────────────────────────────────────────────────────────
# Must match the SECRET_KEY in medchain-server/medchain_backend/settings.py
JWT_SECRET=django-insecure-=368c99s73=ih5%4*mlh1f()0zkovo7#!j2#-j*=%4#3h-iat%
JWT_ALGORITHM=HS256

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
